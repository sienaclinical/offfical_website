---
import { Image } from "astro:assets";
import iconConsultation from "../assets/siena-icon/SVG (Vector)/Consultation.svg";
import iconResearch from "../assets/siena-icon/SVG (Vector)/Research.svg";
import iconUpskill from "../assets/siena-icon/SVG (Vector)/Upskill 01.svg";

const capabilities = [
  {
    title: "Consultation",
    description:
      "We are pleased to collaborate as a thought partner in supporting your initiatives. Recognizing the varying needs of each engagement, we offer multiple consultation frameworks—ranging from fixed-scope consultancy and modular engagements to retainer-based advisory and on-demand analytical support.",
    icon: iconConsultation,
    alt: "Consultation illustration",
  },
  {
    title: "Research",
    description:
      "We welcome academia, practitioners, governmental institutions, and other healthcare stakeholders to collaborate with Siena Clinical performing high quality scientific research to solve real clinical problems and further to implement the findings to the real practice. We offer consultations on research ideas, study design, or research proposals. We are also open to collaborations to expand your research idea into protocol, to conduct and manage data collection (including the development of electronic/web-based database, forms), data analysis, and reporting or publication.",
    icon: iconResearch,
    alt: "Research illustration",
  },
  {
    title: "Upskilling",
    description:
      "Siena clinical is not only committed to improve the quality of the clinical research in Indonesia, but also to the development of fundamental knowledge and skills in research and health science. We provide training, workshops & short course that are delivered by the experts on each particular topic. Our educational activities cover (but not limited to)",
    list: [
      "(1) Systematic literature studies;",
      "(2) Meta-analysis;",
      "(3) Research design and clinical epidemiology;",
      "(4) Biostatistics (theory and practical);",
      "(5) Basic statistics: exploratory data analysis, inference statistics, parametric and non-parametric methods for statistical test;",
      "(6) Advance statistics: generalized linear regression & mixed-models;",
      "(7) Using statistical tools (options: R and SPSS) for data analysis.",
    ],
    icon: iconUpskill,
    alt: "Upskilling illustration",
  },
];
---

<div class="relative">
  <div
    class="absolute inset-y-0 left-1/2 transform -translate-x-1/2 w-0.5 bg-yellow-200/60 z-0 rounded-full"
  >
  </div>

  <div class="flex flex-col gap-32 relative z-10">
    {
      capabilities.map((item, index) => {
        const isImageLeft = index % 2 === 0;

        return (
          <div class="relative flex items-center w-full group">
            <div class="absolute left-1/2 transform -translate-x-1/2 flex items-center justify-center w-10 h-10 rounded-full bg-white border-2 border-yellow-300 shadow-sm z-20 transition-transform duration-300 group-hover:scale-110 group-hover:border-yellow-400 group-hover:shadow-md">
              <span class="text-yellow-600 font-bold text-sm">{index + 1}</span>
            </div>

            <div class="w-1/2 flex justify-end pr-14">
              {isImageLeft ? (
                <div class="w-64 h-64 flex items-center justify-center transition-transform duration-500 group-hover:-translate-y-2">
                  <Image
                    src={item.icon}
                    alt={item.alt}
                    class="w-full h-full object-contain filter drop-shadow-lg"
                  />
                </div>
              ) : (
                <div class="text-right max-w-lg transition-all duration-300 group-hover:-translate-x-1 opacity-95 group-hover:opacity-100">
                  <h3 class="text-2xl font-bold text-siena-primary mb-5">
                    {item.title}
                  </h3>
                  <p class="text-gray-600 leading-relaxed text-[15px]">
                    {item.description}
                  </p>
                  {item.list && (
                    <ul class="text-gray-600 text-[14px] mt-4 space-y-2 list-none">
                      {item.list.map((listItem) => (
                        <li class="flex justify-end gap-2 items-start">
                          <span>{listItem}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              )}
            </div>

            <div class="w-1/2 flex justify-start pl-14">
              {!isImageLeft ? (
                <div class="w-64 h-64 flex items-center justify-center transition-transform duration-500 group-hover:-translate-y-2">
                  <Image
                    src={item.icon}
                    alt={item.alt}
                    class="w-full h-full object-contain filter drop-shadow-lg"
                  />
                </div>
              ) : (
                <div class="text-left max-w-lg transition-all duration-300 group-hover:translate-x-1 opacity-95 group-hover:opacity-100">
                  <h3 class="text-2xl font-bold text-siena-primary mb-5">
                    {item.title}
                  </h3>
                  <p class="text-gray-600 leading-relaxed text-[15px]">
                    {item.description}
                  </p>
                  {item.list && (
                    <ul class="text-gray-600 text-[14px] mt-4 space-y-2 list-none">
                      {item.list.map((listItem) => (
                        <li class="flex justify-start gap-2 items-start">
                          <span class="text-siena-cyan/80 mt-1.5 w-1.5 h-1.5 rounded-full bg-siena-cyan shrink-0 block" />
                          <span>{listItem}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              )}
            </div>
          </div>
        );
      })
    }
  </div>
</div>
