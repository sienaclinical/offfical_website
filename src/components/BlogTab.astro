---
import { Image } from "astro:assets";

import imgFamilyBonds from "../assets/publication/How-Family-Bonds Shape-Our-Mental-Health.png";
import imgFastingPregnancy from "../assets/publication/Clinical-Impacts-and-Management-of-Intermittent-Fasting-in-Pregnancy.png";
import imgJakartaPatientExp from "../assets/publication/Assessing-Patient-Experiences-with-Healthcare-Providers-in-Jakarta.jpeg";

const iconKey = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M7 14a4 4 0 1 1 3.46-6H22v4h-2v2h-2v2h-4.54A4 4 0 0 1 7 14Zm0-6a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z"/></svg>`;
const iconArrow = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M13 5h6v6h-2V8.41l-8.29 8.3-1.42-1.42 8.3-8.29H13V5Z"/><path d="M5 7h6V5H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-6h-2v6H5V7Z"/></svg>`;

const posts = [
  {
    title: "How Family Bonds Shape Our Mental Health",
    description: [
      "Healthy family bonds are more than just a tradition; they’re a powerful shield that protects our mental health from life's daily stress.",
      'Science shows that staying connected can actually boost our survival chances by 50%, making "silaturahmi" a biological must-have.',
    ],
    link: {
      href: "https://www.instagram.com/p/DV7ofrukRCK/?img_index=1",
      label: "Read more",
    },
    image: imgFamilyBonds,
    imageAlt: "How Family Bonds Shape Our Mental Health poster",
  },
  {
    title: "Clinical Impacts and Management of Intermittent Fasting in Pregnancy",
    description: [
      'Pregnancy is a journey of incredible transformation, where your body’s main mission is to prioritize your baby’s growth. For those considering intermittent fasting, understanding the science behind your body\'s "accelerated starvation" mode is the first step to staying safe and strong.',
      "This article breaks down the clinical guidelines from Global- and Regional- health authorities to help you navigate this period with confidence and clarity. From hydration protocols to \"red flag\" symptoms, being informed means being empowered.",
    ],
    link: {
      href: "https://www.linkedin.com/pulse/clinical-impacts-management-intermittent-fasting-pregnancy-pcnlc",
      label: "Read more",
    },
    image: imgFastingPregnancy,
    imageAlt:
      "Clinical Impacts and Management of Intermittent Fasting in Pregnancy poster",
  },
  {
    title: "Assessing Patient Experiences with Healthcare Providers in Jakarta",
    description: [
      "Our analysis unveils both positive aspects and areas for improvement in hospital services, with 65% of reviews expressing positive sentiments. Notably, pharmacy services received the most negative feedback, while medical team collaboration garnered widespread appreciation.",
    ],
    keyFindings: [
      "Hospitals like RS Pondok Indah - Pondok Indah and RS Pondok Indah - Puri Indah boast high ratings and popularity, while RSUP Persahabatan and RSUP Fatmawati received lower ratings.",
      "Sentiment analysis revealed that 65% of reviews had a positive tone, indicating a willingness to provide feedback and appreciation for hospital services.",
      "Ten distinct topics emerged from the reviews, ranging from parking convenience and medical services to pharmacy processes and patient care.",
      "Pharmacy services received the most negative sentiment (70%), with complaints mainly revolving around wait times and queues. Conversely, medical team collaboration received predominantly positive sentiment, highlighting patient appreciation for vaccination services and specialist medical care.",
    ],
    link: {
      href: "https://drive.google.com/file/d/1W6OSBHUrU1XWkK7k3IemjmfwHqcm7Ekp/view?usp=sharing",
      label: "Read more",
    },
    image: imgJakartaPatientExp,
    imageAlt:
      "Assessing Patient Experiences with Healthcare Providers in Jakarta poster",
  },
];
---

<div class="space-y-18">
  {
    posts.map((post) => (
      <article class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] items-start">
        <div class="space-y-4">
          <h2 class="text-2xl md:text-[26px] font-semibold text-siena-primary leading-tight">
            {post.title}
          </h2>

          <div class="space-y-4 text-gray-600 leading-relaxed text-[15px]">
            {post.description.map((p) => (
              <p>{p}</p>
            ))}
          </div>

          {post.keyFindings && (
            <div class="mt-5">
              <div class="flex items-center gap-2 text-gray-900 font-semibold mb-3">
                <span class="text-siena-cyan" set:html={iconKey} />
                <span>Key Findings</span>
              </div>
              <ul class="space-y-3 text-gray-600 text-[14.5px] leading-relaxed">
                {post.keyFindings.map((finding) => (
                  <li class="flex gap-3 items-start">
                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-siena-cyan shrink-0 block" />
                    <span>{finding}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <a
            href={post.link.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 text-[13px] font-semibold text-amber-500 hover:text-amber-600 transition-colors"
          >
            <span>{post.link.label}</span>
            <span class="text-amber-500" set:html={iconArrow} />
          </a>
        </div>

        <div class="w-full flex justify-center lg:justify-end">
          <div class="w-full max-w-[360px] rounded-xl overflow-hidden border border-gray-100 shadow-sm bg-white">
            <Image
              src={post.image}
              alt={post.imageAlt}
              class="w-full h-auto object-cover"
              widths={[480, 720]}
              sizes="(max-width: 1024px) 90vw, 360px"
              loading="lazy"
            />
          </div>
        </div>
      </article>
    ))
  }
</div>

