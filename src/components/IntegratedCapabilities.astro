---
// Integrated Capabilities Component
import { Image } from 'astro:assets';
import researchIcon from '../assets/siena-icon/Dark Blue/Research (Blue).png';
import consultationIcon from '../assets/siena-icon/Dark Blue/Consultation.png';
import upskillIcon from '../assets/siena-icon/Dark Blue/Upskill (2).png';

const capabilities = [
  {
    id: 'research',
    title: 'Research',
    description: 'We are your full partner for everything from strategy to execution.',
    iconSrc: researchIcon,
    iconAlt: 'Research Icon',
    readMoreUrl: '/capability?tab=research#capability-tabs'
  },
  {
    id: 'consultation',
    title: 'Consultation',
    description: 'We are more than happy to be your thinking partner for your project',
    iconSrc: consultationIcon,
    iconAlt: 'Consultation Icon',
    readMoreUrl: '/capability?tab=consultation#capability-tabs'
  },
  {
    id: 'upskilling',
    title: 'Upskilling',
    description: 'We provide tailored-needs training, workshops and short-courses',
    iconSrc: upskillIcon,
    iconAlt: 'Upskill Icon',
    readMoreUrl: '/capability?tab=upskilling#capability-tabs'
  }
];
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center max-w-4xl mx-auto mb-16">
      <h2 class="font-heading text-3xl font-semibold text-siena-primary mb-6">
        One organization. Three integrated capabilities
      </h2>
      <p class="text-gray-600 leading-relaxed text-base">
        Siena Clinical is a Research Ecosystem Partner from Indonesia that integrates clinical research, strategic consultation, and professional upskilling within a single hybrid structure. We bridge Academia and Industry with scientific standards that can be fully accounted for.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      {capabilities.map((item) => (
        <a
          href={item.readMoreUrl}
          class="group flex flex-col items-center rounded-3xl px-6 py-8 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-siena-cyan focus-visible:ring-offset-2"
          aria-label={`Open ${item.title} capability tab`}
        >
          <!-- Icon Image -->
          <div class="mb-6 h-20 flex justify-center items-center">
            <Image src={item.iconSrc} alt={item.iconAlt} class="max-h-full w-auto object-contain" />
          </div>
          
          <h3 class="font-heading text-xl font-bold text-siena-primary mb-3">
            {item.title}
          </h3>
          
          <p class="text-gray-600 leading-relaxed text-sm md:text-base max-w-xs mx-auto">
            {item.description}
          </p>

          <span class="mt-4 inline-flex items-center gap-1 text-yellow-500 font-medium">
            Read more <span aria-hidden="true">&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
