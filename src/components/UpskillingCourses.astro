---
import { getCollection } from "astro:content";

const courses = (await getCollection("courses"))
  .filter((course) => course.data.published)
  .sort((a, b) => a.data.order - b.data.order);

const getCourseSlug = (course: (typeof courses)[number]) => course.id;
---

  <!-- Section subtitle -->
  <div class="text-center mb-10">
    <p class="text-sm text-gray-500 leading-relaxed">
      We provide interactive sessions and up-to-date information through our workshops and courses,
      which will help practitioners and students in the medical field to better conduct research.
      The courses and workshops will include case studies, group activities, and discussion sessions
      that will help participants to understand and apply the material in a practical manner.
    </p>
  </div>

  <!-- Course List -->
  <div class="flex flex-col gap-5">
    {
      courses.map((course) => (
        <a
          href={`/courses/${getCourseSlug(course)}`}
          class="group relative flex items-start gap-4 bg-white border border-gray-100 rounded-2xl px-8 py-6 shadow-sm hover:shadow-md hover:border-cyan-200 hover:-translate-y-0.5 transition-all duration-200 overflow-hidden"
        >
          <!-- Left accent bar on hover -->
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-[#8EEDFE] to-[#3D4766] rounded-l-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-200" />

          <!-- Icon -->
          <div class="flex-shrink-0 flex items-center justify-center w-11 h-11 rounded-xl bg-sky-50 text-[#3D4766] group-hover:bg-cyan-50 transition-colors duration-200" set:html={course.data.icon} />

          <!-- Content -->
          <div class="flex-1 min-w-0">
            <div class="mb-1.5">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider bg-sky-50 text-[#3D4766] border border-sky-200">
                {course.data.badge}
              </span>
            </div>
            <h3 class="font-semibold text-[17px] text-gray-900 mb-1.5 leading-snug" style="font-family: 'Prompt', sans-serif;">
              {course.data.title}
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed">
              {course.data.descriptionId || course.data.description}
            </p>
          </div>

          <!-- Arrow indicator -->
          <div class="flex-shrink-0 self-center text-gray-300 group-hover:text-[#3D4766] group-hover:translate-x-1 transition-all duration-200">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
              <path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
            </svg>
          </div>
        </a>
      ))
    }
  </div>
