---
import { Image } from 'astro:assets';
import logo from '../assets/logo/SIENA CLINICAL LOGO 2 (COLOR).png';

const currentYear = new Date().getFullYear();
---

<footer class="w-full py-12 px-6 border-t border-gray-100 mt-auto">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-end gap-8">
    
    <!-- Left Column: Logo & Socials -->
    <div class="flex flex-col gap-6">
      <Image
        src={logo}
        alt="Siena Clinical"
        class="h-10 w-auto object-contain"
        widths={[300, 600]}
        sizes="300px"
      />
      <div class="flex items-center gap-4">
        <a href="https://linkedin.com/company/siena-clinical" target="_blank" rel="noopener noreferrer" class="text-siena-cyan hover:text-siena-primary transition-colors" aria-label="LinkedIn">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://instagram.com/siena_clinical" target="_blank" rel="noopener noreferrer" class="text-siena-cyan hover:text-siena-primary transition-colors" aria-label="Instagram">
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
          </svg>
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <nav class="flex flex-col gap-3" aria-label="Footer navigation">
      <p class="text-sm font-semibold text-siena-primary tracking-wide uppercase">Quick Links</p>
      <a href="/" class="text-sm text-gray-500 hover:text-siena-cyan transition-colors">Home</a>
      <a href="/capability" class="text-sm text-gray-500 hover:text-siena-cyan transition-colors">Capability</a>
      <a href="/publication" class="text-sm text-gray-500 hover:text-siena-cyan transition-colors">Publication</a>
      <a href="/team" class="text-sm text-gray-500 hover:text-siena-cyan transition-colors">Team</a>
      <a href="/contact" class="text-sm text-gray-500 hover:text-siena-cyan transition-colors">Contact</a>
    </nav>

    <!-- Right Column: Contact & Copyright -->
    <div class="flex flex-col md:items-end gap-4 text-left md:text-right">
      <a
        href="/contact"
        class="group inline-flex items-center gap-2 self-start md:self-end rounded-full border border-siena-primary/20 bg-siena-primary px-5 py-3 font-heading text-base font-semibold text-white shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:border-siena-cyan hover:bg-siena-cyan focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-siena-cyan focus-visible:ring-offset-2 cursor-pointer"
        aria-label="Contact Siena Clinical"
      >
        <span>Contact us</span>
        <svg
          class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.167 10h11.666M10.833 4.167 15.833 10l-5 5.833" />
        </svg>
      </a>
      <address class="not-italic text-sm leading-6 text-gray-600">
        Menara Cakrawala 12th Floor Unit 5A<br />
        Jl. M.H. Thamrin No.Kav. 9, Kebon Sirih, Menteng<br />
        DKI Jakarta 10340<br />
        Indonesia
      </address>
      <p class="text-sm text-gray-500">
        Copyright &copy;{currentYear} Siena Clinical. All rights reserved.
      </p>
    </div>

  </div>
</footer>
