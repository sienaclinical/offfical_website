---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const iconKey = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M7 14a4 4 0 1 1 3.46-6H22v4h-2v2h-2v2h-4.54A4 4 0 0 1 7 14Zm0-6a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z"/></svg>`;
const iconArrow = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M13 5h6v6h-2V8.41l-8.29 8.3-1.42-1.42 8.3-8.29H13V5Z"/><path d="M5 7h6V5H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-6h-2v6H5V7Z"/></svg>`;

const posts = (await getCollection("blogs"))
  .filter((post) => post.data.published)
  .sort((a, b) => a.data.order - b.data.order);
---

<div class="space-y-18">
  {
    posts.map((post) => (
      <article class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] items-start">
        <div class="space-y-4">
          <h2 class="text-2xl md:text-[26px] font-semibold text-siena-primary leading-tight">
            {post.data.title}
          </h2>

          <div class="space-y-4 text-gray-600 leading-relaxed text-[15px]">
            {post.data.description.map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>

          {post.data.keyFindings && (
            <div class="mt-5">
              <div class="flex items-center gap-2 text-gray-900 font-semibold mb-3">
                <span class="text-siena-cyan" set:html={iconKey} />
                <span>Key Findings</span>
              </div>
              <ul class="space-y-3 text-gray-600 text-[14.5px] leading-relaxed">
                {post.data.keyFindings.map((finding) => (
                  <li class="flex gap-3 items-start">
                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-siena-cyan shrink-0 block" />
                    <span>{finding}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <a
            href={post.data.link.href}
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 text-[13px] font-semibold text-amber-500 hover:text-amber-600 transition-colors"
          >
            <span>{post.data.link.label}</span>
            <span class="text-amber-500" set:html={iconArrow} />
          </a>
        </div>

        <div class="w-full flex justify-center lg:justify-end">
          <div class="w-full max-w-[360px] rounded-xl overflow-hidden border border-gray-100 shadow-sm bg-white">
            <Image
              src={post.data.image}
              alt={post.data.imageAlt}
              class="w-full h-auto object-cover"
              widths={[480, 720]}
              sizes="(max-width: 1024px) 90vw, 360px"
              loading="lazy"
            />
          </div>
        </div>
      </article>
    ))
  }
</div>
