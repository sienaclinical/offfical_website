---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const iconArrow = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M13 5h6v6h-2V8.41l-8.29 8.3-1.42-1.42 8.3-8.29H13V5Z"/><path d="M5 7h6V5H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-6h-2v6H5V7Z"/></svg>`;

const carousel = (await getCollection("pastEventHighlights"))
  .filter((slide) => slide.data.published)
  .sort((a, b) => a.data.order - b.data.order);

const events = (await getCollection("pastEvents"))
  .filter((event) => event.data.published)
  .sort((a, b) => a.data.order - b.data.order);
---

<div class="space-y-14" data-past-events>
  <section class="rounded-4xl border border-gray-100 bg-white p-6 md:p-8 shadow-sm">
    <div class="flex items-center justify-between gap-4 mb-5">
      <div>
        <p class="text-sm uppercase tracking-[0.35em] text-siena-cyan mb-2">
          Past events
        </p>
        <h2 class="text-2xl md:text-3xl font-semibold text-siena-primary">
          Highlights
        </h2>
      </div>

      <div class="flex items-center gap-2">
        <button
          type="button"
          class="carousel-prev inline-flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 text-gray-700 hover:bg-slate-50 transition-colors"
          aria-label="Previous slide"
        >
          <span aria-hidden="true">&lsaquo;</span>
        </button>
        <button
          type="button"
          class="carousel-next inline-flex items-center justify-center w-10 h-10 rounded-full border border-gray-200 text-gray-700 hover:bg-slate-50 transition-colors"
          aria-label="Next slide"
        >
          <span aria-hidden="true">&rsaquo;</span>
        </button>
      </div>
    </div>

    <div class="carousel relative overflow-hidden rounded-3xl bg-slate-50">
      <div class="carousel-track flex transition-transform duration-500 ease-out">
        {carousel.map((slide) => (
          <div class="carousel-slide w-full shrink-0">
            <Image
              src={slide.data.image}
              alt={slide.data.imageAlt}
              class="w-full h-[240px] sm:h-[320px] md:h-[420px] object-cover"
              widths={[960, 1440]}
              sizes="(max-width: 768px) 100vw, 960px"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>

    <div class="carousel-dots flex items-center justify-center gap-2 mt-5" aria-label="Carousel pagination">
      {carousel.map((slide, idx) => (
        <button
          type="button"
          class:list={[
            "carousel-dot w-2.5 h-2.5 rounded-full transition-all",
            idx === 0 ? "bg-siena-cyan w-7" : "bg-gray-200 hover:bg-gray-300",
          ]}
          data-index={idx}
          aria-label={`Go to ${slide.data.title}`}
        />
      ))}
    </div>
  </section>

  <section class="space-y-18">
    {events.map((event) => (
      <article class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] items-start">
        <div class="space-y-4">
          <h3 class="text-2xl md:text-[26px] font-semibold text-siena-primary leading-tight">
            {event.data.title}
          </h3>

          <div class="space-y-4 text-gray-600 leading-relaxed text-[15px]">
            {event.data.description.map((paragraph) =>
              /^\d+\.\s/.test(paragraph) ? (
                <p class="pl-4">
                  <span class="text-siena-cyan/80 -ml-4 mr-2">&bull;</span>
                  {paragraph.replace(/^\d+\.\s/, "")}
                </p>
              ) : (
                <p>{paragraph}</p>
              ),
            )}
          </div>

          {event.data.link && (
            <a
              href={event.data.link.href}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 text-[13px] font-semibold text-amber-500 hover:text-amber-600 transition-colors"
            >
              <span>{event.data.link.label}</span>
              <span class="text-amber-500" set:html={iconArrow} />
            </a>
          )}
        </div>

        <div class="w-full flex justify-center lg:justify-end">
          <div class="w-full max-w-[420px] rounded-xl overflow-hidden border border-gray-100 shadow-sm bg-white">
            <Image
              src={event.data.image}
              alt={event.data.imageAlt}
              class="w-full h-auto object-cover"
              widths={[720, 960]}
              sizes="(max-width: 1024px) 90vw, 420px"
              loading="lazy"
            />
          </div>
        </div>
      </article>
    ))}
  </section>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const AUTOPLAY_INTERVAL = 4000;
    let autoplayTimer: ReturnType<typeof setInterval>;
    const root = document.querySelector<HTMLElement>("[data-past-events]");
    if (!root) return;

    const track = root.querySelector<HTMLElement>(".carousel-track");
    const slides = Array.from(
      root.querySelectorAll<HTMLElement>(".carousel-slide"),
    );
    const dots = Array.from(root.querySelectorAll<HTMLButtonElement>(".carousel-dot"));
    const prev = root.querySelector<HTMLButtonElement>(".carousel-prev");
    const next = root.querySelector<HTMLButtonElement>(".carousel-next");

    if (!track || slides.length === 0) return;

    let index = 0;

    const setIndex = (nextIndex: number) => {
      index = (nextIndex + slides.length) % slides.length;
      track.style.transform = `translateX(-${index * 100}%)`;

      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-siena-cyan", i === index);
        dot.classList.toggle("w-7", i === index);
        dot.classList.toggle("bg-gray-200", i !== index);
        dot.setAttribute("aria-current", i === index ? "true" : "false");
      });
    };

    const startAutoplay = () => {
      autoplayTimer = setInterval(() => setIndex(index + 1), AUTOPLAY_INTERVAL);
    };

    const resetAutoplay = () => {
      clearInterval(autoplayTimer);
      startAutoplay();
    };

    prev?.addEventListener("click", () => {
      setIndex(index - 1);
      resetAutoplay();
    });
    next?.addEventListener("click", () => {
      setIndex(index + 1);
      resetAutoplay();
    });

    dots.forEach((dot) => {
      dot.addEventListener("click", () => {
        const i = Number(dot.getAttribute("data-index"));
        if (!Number.isFinite(i)) return;
        setIndex(i);
        resetAutoplay();
      });
    });

    const carouselEl = root.querySelector(".carousel");
    carouselEl?.addEventListener("mouseenter", () => clearInterval(autoplayTimer));
    carouselEl?.addEventListener("mouseleave", () => startAutoplay());

    setIndex(0);
    startAutoplay();
  });
</script>
