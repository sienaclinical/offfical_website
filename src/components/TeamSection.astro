---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

type TeamEntry = CollectionEntry<"team">;
type LinkKind = NonNullable<TeamEntry["data"]["links"]>[number]["kind"];

interface Props {
  title: string;
  description: string;
  members: TeamEntry[];
  columnsClass?: string;
  cardClass?: string;
  containerClass?: string;
  showRole?: boolean;
  showLinks?: boolean;
}

const {
  title,
  description,
  members,
  columnsClass = "flex flex-wrap justify-center gap-6 lg:gap-8",
  cardClass = "bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center flex flex-col w-full sm:basis-[calc(50%-0.75rem)] lg:basis-[calc(25%-1.5rem)] max-w-[320px]",
  containerClass = "pt-16 pb-6",
  showRole = true,
  showLinks = false,
} = Astro.props;

const iconMap: Record<LinkKind, string> = {
  linkedin: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1 4.98 2.12 4.98 3.5ZM.22 8.09H4.8V24H.22V8.09ZM8.09 8.09H12.5V10.1h.06c.61-1.16 2.1-2.38 4.32-2.38 4.62 0 5.48 3.04 5.48 7V24h-4.6v-7.5c0-1.79-.03-4.1-2.5-4.1-2.5 0-2.88 1.95-2.88 3.97V24H8.09V8.09Z"/></svg>`,
  scholar: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 3 1 9l11 6 9-4.91V17h2V9L12 3Zm0 14L4.24 12.8 12 8.6l7.76 4.2L12 17Z"/><path d="M12 14.5 6 11.2v4.3c0 1.93 2.69 3.5 6 3.5s6-1.57 6-3.5v-4.3l-6 3.3Z"/></svg>`,
  github: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path fill-rule="evenodd" d="M12 2C6.48 2 2 6.58 2 12.26c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.48 0-.24-.01-.87-.01-1.7-2.78.62-3.37-1.36-3.37-1.36-.46-1.19-1.11-1.5-1.11-1.5-.9-.63.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.37-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.27 2.75 1.05A9.32 9.32 0 0 1 12 6.84c.85 0 1.7.12 2.5.35 1.9-1.32 2.74-1.05 2.74-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.81-4.57 5.07.36.32.68.95.68 1.92 0 1.38-.01 2.5-.01 2.84 0 .26.18.59.69.48A10.03 10.03 0 0 0 22 12.26C22 6.58 17.52 2 12 2Z" clip-rule="evenodd"/></svg>`,
};
---

<section class={containerClass}>
  <div class="text-center max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-semibold text-siena-primary mb-4 font-prompt">
      {title}
    </h2>
    <p class="text-gray-600 leading-relaxed text-[15px] md:text-[15.5px]">
      {description}
    </p>
  </div>

  <div class:list={["mt-12", columnsClass]}>
    {members.map((member) => (
      <article class={cardClass}>
        <div class="mx-auto w-20 h-20 rounded-full overflow-hidden border border-gray-100 bg-slate-50">
          <Image
            src={member.data.image}
            alt={member.data.name}
            class="w-full h-full object-cover"
            widths={[160, 240]}
            sizes="80px"
            loading="lazy"
          />
        </div>

        <h3 class="mt-5 text-[15px] font-bold text-gray-900 leading-snug">
          {member.data.name}
        </h3>

        {showRole && (
          <p class="mt-1 text-[12.5px] font-semibold text-gray-500">
            {member.data.role}
          </p>
        )}

        <p class="mt-4 text-[13.5px] text-gray-600 leading-relaxed flex-1">
          {member.data.bio}
        </p>

        {showLinks && member.data.links && member.data.links.length > 0 && (
          <div class="mt-5 flex items-center justify-center gap-4">
            {member.data.links.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-gray-200 text-gray-700 hover:bg-slate-50 hover:text-siena-primary transition-colors"
                aria-label={link.label}
                title={link.label}
              >
                <span set:html={iconMap[link.kind]} />
              </a>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
</section>
