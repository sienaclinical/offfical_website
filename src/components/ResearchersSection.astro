---

<section class="pt-10 pb-6">
  <div class="text-center max-w-5xl mx-auto">
    <h1 class="text-3xl md:text-4xl font-semibold text-siena-primary mb-4 font-prompt">
      Researchers
    </h1>
    <p class="text-gray-600 leading-relaxed text-[15px] md:text-[15.5px]">
      Our researchers serve as your full strategic partners, from study design
      and protocol development to advanced data analysis and final reporting.
      Our diverse scientific board leverages years of experience in
      epidemiology, biostatistics, and clinical medicine to tackle the most
      pressing health challenges. We don’t just collect data; we transform it
      into actionable evidence that empowers academia, government institutions,
      and healthcare stakeholders.
    </p>
  </div>

  <div class="mt-12 flex flex-wrap justify-center gap-6 lg:gap-8">
    {researchers.map((p) => (
      <article class="bg-white border border-gray-100 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center flex flex-col w-full sm:basis-[calc(50%-0.75rem)] lg:basis-[calc(25%-1.5rem)] max-w-[320px]">
        <div class="mx-auto w-20 h-20 rounded-full overflow-hidden border border-gray-100 bg-slate-50">
          <Image
            src={p.image}
            alt={p.name}
            class="w-full h-full object-cover"
            widths={[160, 240]}
            sizes="80px"
            loading="lazy"
          />
        </div>

        <h3 class="mt-5 text-[15px] font-bold text-gray-900 leading-snug">
          {p.name}
        </h3>
        <p class="mt-1 text-[12.5px] font-semibold text-gray-500">
          {p.role}
        </p>
        <p class="mt-4 text-[13.5px] text-gray-600 leading-relaxed flex-1">
          {p.bio}
        </p>

        {p.links && p.links.length > 0 && (
          <div class="mt-5 flex items-center justify-center gap-4">
            {p.links.map((l) => (
              <a
                href={l.href}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-gray-200 text-gray-700 hover:bg-slate-50 hover:text-siena-primary transition-colors"
                aria-label={l.label}
                title={l.label}
              >
                <span set:html={iconMap[l.kind]} />
              </a>
            ))}
          </div>
        )}
      </article>
    ))}
  </div>
</section>

