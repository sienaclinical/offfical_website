const carousel = [
  { src: c1, alt: "Past event highlight 1" },
  { src: c2, alt: "Past event highlight 2" },
  { src: c3, alt: "Past event highlight 3" },
  { src: c4, alt: "Past event highlight 4" },
  { src: c5, alt: "Past event highlight 5" },
  { src: c6, alt: "Past event highlight 6" },
  { src: c7, alt: "Past event highlight 7" },
