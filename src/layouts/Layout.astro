---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import supergraphic from '../assets/Supergraphic Siena Clinical (Blue).webp';
import defaultOgImage from '../assets/logo/SIENA CLINICAL LOGO 2 (COLOR).png';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  openGraphType?: 'website' | 'article';
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  breadcrumbLabel?: string;
}

const {
  title = 'Siena Clinical | Clinical Research, Consulting, and Upskilling',
  description = 'Siena Clinical is a clinical research organization providing consultation, research collaboration, scientific publications, and professional upskilling programs in Indonesia.',
  image = defaultOgImage.src,
  noindex = false,
  openGraphType = 'website',
  structuredData,
  breadcrumbLabel,
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://www.sienaclinical.com');
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const resolvedImage = image.startsWith('http')
  ? image
  : new URL(image, siteUrl).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Siena Clinical',
  alternateName: 'PT Siena Sains Medika',
  url: siteUrl.toString(),
  logo: new URL(defaultOgImage.src, siteUrl).toString(),
  email: 'info@sienaclinical.com',
  sameAs: [
    'https://linkedin.com/company/siena-clinical',
    'https://instagram.com/siena_clinical',
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Menara Cakrawala 12th Floor Unit 5A, Jl. M.H. Thamrin No.Kav. 9, Kebon Sirih, Menteng',
    addressLocality: 'Jakarta',
    postalCode: '10340',
    addressCountry: 'ID',
  },
};

const siteNavSchema = {
  '@context': 'https://schema.org',
  '@type': 'SiteNavigationElement',
  name: ['Home', 'Capability', 'Publication', 'Team', 'Contact'],
  url: [
    siteUrl.toString(),
    `${siteUrl}capability`,
    `${siteUrl}publication`,
    `${siteUrl}team`,
    `${siteUrl}contact`,
  ],
};

const breadcrumbSchema = breadcrumbLabel
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: siteUrl.toString(),
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: breadcrumbLabel,
          item: canonicalUrl,
        },
      ],
    }
  : null;

const pageSchemas = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const schemas = [
  organizationSchema,
  siteNavSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...pageSchemas,
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="theme-color" content="#3D4766" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:site_name" content="Siena Clinical" />
		<meta property="og:type" content={openGraphType} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={resolvedImage} />
		<meta property="og:locale" content="en_US" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={resolvedImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=link_2" rel="stylesheet" />
		<title>{title}</title>
		{
			schemas.map((schema) => (
				<script type="application/ld+json" set:html={JSON.stringify(schema)} />
			))
		}
	</head>
	<body class="font-sans text-siena-primary bg-white relative min-h-screen flex flex-col">
		<!-- Global Supergraphic Watermark -->
		<div 
			class="fixed inset-0 z-[0] opacity-[0.05] pointer-events-none mix-blend-multiply"
			style={`background-image: url('${supergraphic.src}'); background-size: cover; background-position: center; background-repeat: no-repeat;`}
		></div>
		
		<div class="relative z-10 flex flex-col flex-1">
			<Header />
			<main class="flex-1">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
