---
import Layout from "../layouts/Layout.astro";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: "Contact Siena Clinical",
  url: "https://www.sienaclinical.com/contact",
  mainEntity: {
    "@type": "Organization",
    name: "Siena Clinical",
    email: "info@sienaclinical.com",
    sameAs: [
      "https://linkedin.com/company/siena-clinical",
      "https://instagram.com/siena_clinical",
    ],
  },
};
---

<Layout
  title="Contact Siena Clinical | Research and Consultation Inquiries"
  description="Contact Siena Clinical for clinical research collaboration, consultation, publications, and upskilling inquiries."
  structuredData={contactSchema}
>
  <main class="w-full min-h-screen pb-24">
    <!-- Hero / Contact Form Section -->
    <section class="relative overflow-hidden pt-36 pb-20 bg-gradient-to-br from-siena-primary via-[#4a567a] to-siena-primary">
      <!-- Decorative circles -->
      <div class="absolute -top-24 -right-24 w-72 h-72 bg-siena-cyan/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-16 -left-16 w-56 h-56 bg-siena-cyan/10 rounded-full blur-3xl"></div>

      <div class="max-w-3xl mx-auto px-6 text-center relative z-10">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-white mb-4">
          Let's Get In Touch
        </h1>
        <p class="text-white/80 text-lg md:text-xl max-w-xl mx-auto mb-12">
          We would love to hear from you! Contact us and share any questions and/or inquiries you may have.
        </p>

        <!-- Contact Form Card -->
        <div class="bg-white rounded-2xl shadow-2xl p-8 md:p-10 text-left">
          <form id="contact-form" class="flex flex-col gap-6" novalidate>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="fullName" class="text-sm font-semibold text-siena-primary">Full Name</label>
                <input
                  type="text"
                  id="fullName"
                  name="fullName"
                  placeholder="Your full name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 text-siena-primary placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-siena-cyan/50 focus:border-siena-cyan transition-all duration-200"
                />
              </div>
              <div class="flex flex-col gap-2">
                <label for="email" class="text-sm font-semibold text-siena-primary">Email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="you@example.com"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 text-siena-primary placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-siena-cyan/50 focus:border-siena-cyan transition-all duration-200"
                />
              </div>
            </div>

            <div class="flex flex-col gap-2">
              <label for="subject" class="text-sm font-semibold text-siena-primary">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="How can we help?"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 text-siena-primary placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-siena-cyan/50 focus:border-siena-cyan transition-all duration-200"
              />
            </div>

            <div class="flex flex-col gap-2">
              <label for="message" class="text-sm font-semibold text-siena-primary">Your Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell us about your inquiry..."
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-gray-50 text-siena-primary placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-siena-cyan/50 focus:border-siena-cyan transition-all duration-200 resize-y"
              ></textarea>
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full md:w-auto md:self-end px-10 py-3.5 bg-siena-cyan text-white font-semibold rounded-lg hover:bg-siena-cyan/90 active:scale-[0.98] transition-all duration-200 shadow-lg shadow-siena-cyan/25 cursor-pointer"
            >
              Submit
            </button>
          </form>

          <!-- Success Message (hidden by default) -->
          <div id="success-message" class="hidden text-center py-8">
            <div class="w-16 h-16 mx-auto mb-4 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <h3 class="font-heading text-2xl font-bold text-siena-primary mb-2">Thank you!</h3>
            <p class="text-gray-500">Your message has been sent. We'll get back to you soon.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Company Information Section -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
          <!-- Company Info -->
          <div class="flex flex-col gap-4">
            <div class="w-12 h-12 bg-siena-primary/10 rounded-xl flex items-center justify-center mb-2">
              <svg class="w-6 h-6 text-siena-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h2 class="font-heading text-xl font-bold text-siena-primary">Siena Clinical</h2>
            <p class="text-gray-500 text-sm leading-relaxed">
              Registered at the Ministry of Law and Human Rights (Kemenkumham) in Indonesia with registered-name as PT Siena Sains Medika; and registry number 0220104161846.
            </p>
          </div>

          <!-- Address -->
          <div class="flex flex-col gap-4">
            <div class="w-12 h-12 bg-siena-cyan/10 rounded-xl flex items-center justify-center mb-2">
              <svg class="w-6 h-6 text-siena-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h2 class="font-heading text-xl font-bold text-siena-primary">Address</h2>
            <div class="text-gray-500 text-sm leading-relaxed">
              <p>Menara Cakrawala 12th Floor Unit 5A</p>
              <p>Jl. M.H. Thamrin No.Kav. 9, Kebon Sirih, Menteng</p>
              <p>DKI Jakarta 10340</p>
              <p>Indonesia</p>
            </div>
          </div>

          <!-- Connect -->
          <div class="flex flex-col gap-4">
            <div class="w-12 h-12 bg-siena-cyan/10 rounded-xl flex items-center justify-center mb-2">
              <svg class="w-6 h-6 text-siena-cyan" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="font-heading text-xl font-bold text-siena-primary">Connect With Us</h2>
            <div class="flex flex-col gap-3 text-sm">
              <a href="mailto:info@sienaclinical.com" class="text-gray-500 hover:text-siena-cyan transition-colors flex items-center gap-2">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                info@sienaclinical.com
              </a>
              <div class="flex items-center gap-4 mt-2">
                <a href="https://linkedin.com/company/siena-clinical" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-siena-primary/10 rounded-lg flex items-center justify-center text-siena-primary hover:bg-siena-cyan hover:text-white transition-all duration-200" aria-label="LinkedIn">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
                <a href="https://instagram.com/siena_clinical" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-siena-primary/10 rounded-lg flex items-center justify-center text-siena-primary hover:bg-siena-cyan hover:text-white transition-all duration-200" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Map Section -->
    <section class="bg-gray-50 border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-6 py-16">
        <h2 class="font-heading text-2xl font-bold text-siena-primary text-center mb-8">Find Us</h2>
        <div class="rounded-2xl overflow-hidden shadow-lg h-[400px]">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.6265074747!2d106.82046307499!3d-6.186461993802!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e69f422a3e5e5e7%3A0xc385f0bfb67b46b0!2sMenara%20Cakrawala!5e0!3m2!1sen!2sid!4v1700000000000!5m2!1sen!2sid"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Siena Clinical Office Location"
          ></iframe>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMessage = document.getElementById('success-message');
    const submitBtn = document.getElementById('submit-btn');

    if (!form || !successMessage || !submitBtn) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Basic client-side validation
      const fullName = (document.getElementById('fullName') as HTMLInputElement).value.trim();
      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

      if (!fullName || !email || !message) {
        // Highlight empty required fields
        const inputs = form.querySelectorAll('[required]');
        inputs.forEach((input) => {
          const el = input as HTMLInputElement | HTMLTextAreaElement;
          if (!el.value.trim()) {
            el.classList.add('ring-2', 'ring-red-400', 'border-red-400');
            el.addEventListener('input', () => {
              el.classList.remove('ring-2', 'ring-red-400', 'border-red-400');
            }, { once: true });
          }
        });
        return;
      }

      // Email format validation
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        const emailInput = document.getElementById('email') as HTMLInputElement;
        emailInput.classList.add('ring-2', 'ring-red-400', 'border-red-400');
        emailInput.addEventListener('input', () => {
          emailInput.classList.remove('ring-2', 'ring-red-400', 'border-red-400');
        }, { once: true });
        return;
      }

      // Simulate submission (static site — no backend)
      submitBtn.textContent = 'Sending...';
      (submitBtn as HTMLButtonElement).disabled = true;

      setTimeout(() => {
        form.classList.add('hidden');
        successMessage.classList.remove('hidden');
      }, 1200);
    });
  });
</script>
