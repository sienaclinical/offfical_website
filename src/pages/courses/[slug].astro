---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const courses = (await getCollection("courses"))
    .filter((entry) => entry.data.published)
    .sort((a, b) => a.data.order - b.data.order);

  const getCourseSlug = (course: (typeof courses)[number]) => course.id;

  return courses.map((course) => ({
    params: { slug: getCourseSlug(course) },
  }));
}

const courses = (await getCollection("courses"))
  .filter((entry) => entry.data.published)
  .sort((a, b) => a.data.order - b.data.order);

const getCourseSlug = (course: (typeof courses)[number]) => course.id;

const { slug } = Astro.params;
const course = courses.find((c) => getCourseSlug(c) === slug);

if (!course) {
  return Astro.redirect("/capability");
}
---

<Layout
  title={`${course.data.title} | Siena Clinical`}
  description={course.data.description}
>
  <main class="w-full min-h-screen pt-16 pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Back link -->
      <div class="pt-10 pb-6">
        <a
          href="/capability"
          class="inline-flex items-center gap-2 text-sm text-gray-400 hover:text-[#3D4766] transition-colors duration-200 group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform duration-200">
            <path fill-rule="evenodd" d="M11.78 5.22a.75.75 0 0 1 0 1.06L8.06 10l3.72 3.72a.75.75 0 1 1-1.06 1.06l-4.25-4.25a.75.75 0 0 1 0-1.06l4.25-4.25a.75.75 0 0 1 1.06 0Z" clip-rule="evenodd" />
          </svg>
          Back to Capability
        </a>
      </div>

      <!-- Split Layout -->
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">

        <!-- Sidebar: Course List -->
        <aside class="lg:w-72 flex-shrink-0">
          <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
            <div class="px-5 py-4 border-b border-gray-100">
              <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">All Courses</p>
            </div>
            <nav class="py-2">
              {
                courses.map((c) => {
                  const isActive = getCourseSlug(c) === slug;
                  return (
                    <a
                      href={`/courses/${getCourseSlug(c)}`}
                      class={`flex items-start gap-3 px-5 py-4 border-l-4 transition-all duration-200 hover:bg-sky-50 ${
                        isActive
                          ? "border-[#3D4766] bg-sky-50"
                          : "border-transparent hover:border-gray-200"
                      }`}
                    >
                      <!-- Icon -->
                      <div
                        class={`flex-shrink-0 flex items-center justify-center w-9 h-9 rounded-lg ${
                          isActive ? "bg-[#3D4766] text-white" : "bg-gray-100 text-gray-500"
                        } transition-colors duration-200`}
                        set:html={c.data.icon}
                      />
                      <div class="min-w-0">
                        <p
                          class={`text-sm font-medium leading-snug ${
                            isActive ? "text-[#3D4766]" : "text-gray-600"
                          }`}
                        >
                          {c.data.title}
                        </p>
                        <p class="text-[11px] text-gray-400 mt-0.5">{c.data.badge}</p>
                      </div>
                    </a>
                  );
                })
              }
            </nav>
          </div>
        </aside>

        <!-- Main Content -->
        <article class="flex-1 min-w-0">
          <div class="bg-white border border-gray-100 rounded-2xl shadow-sm px-10 py-10">

            <!-- Badge -->
            <div class="flex items-center gap-3 mb-5">
              <span class="inline-flex items-center px-3 py-1 rounded-full text-[11px] font-semibold uppercase tracking-wider bg-sky-50 text-[#3D4766] border border-sky-200">
                {course.data.badge}
              </span>
              <span class="text-xs text-gray-400">{course.data.badgeId}</span>
            </div>

            <!-- Title -->
            <h1
              class="text-2xl sm:text-3xl font-semibold text-gray-900 mb-2 leading-tight"
              style="font-family: 'Prompt', sans-serif;"
            >
              {course.data.title}
            </h1>
            <p class="text-base text-gray-400 mb-8 italic" style="font-family: 'Prompt', sans-serif;">
              {course.data.titleId}
            </p>

            <!-- Divider -->
            <div class="border-t border-gray-100 mb-8" />

            <!-- Description EN -->
            <p class="text-sm text-gray-700 leading-relaxed mb-3">
              {course.data.description}
            </p>
            <!-- Description ID -->
            <p class="text-sm text-gray-400 leading-relaxed mb-10 italic">
              {course.data.descriptionId}
            </p>

            <!-- Sections -->
            {
              course.data.sections.map((section) => (
                <div class="mb-8">
                  <h2
                    class="text-base font-semibold text-[#3D4766] mb-4"
                    style="font-family: 'Prompt', sans-serif;"
                  >
                    {section.heading}
                  </h2>
                  <ul class="space-y-2.5">
                    {section.items.map((item) => (
                      <li class="flex items-start gap-3 text-sm text-gray-600">
                        <span class="flex-shrink-0 mt-1.5 w-1.5 h-1.5 rounded-full bg-[#8EEDFE]" />
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }

            <!-- Instructor -->
            {
              course.data.instructor && (
                <div class="flex items-center gap-3 py-5 border-t border-gray-100 mb-8">
                  <div class="w-9 h-9 rounded-full bg-sky-100 flex items-center justify-center flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#3D4766" class="w-5 h-5">
                      <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                  </div>
                  <div>
                    <p class="text-[11px] uppercase tracking-wider text-gray-400 font-semibold">Instructor</p>
                    <p class="text-sm font-medium text-gray-700">{course.data.instructor}</p>
                  </div>
                </div>
              )
            }

            <!-- Register Button -->
            <a
              href={course.data.registerUrl ?? "/contact"}
              target={course.data.registerUrl ? "_blank" : undefined}
              rel={course.data.registerUrl ? "noreferrer" : undefined}
              class="inline-flex items-center gap-2 px-8 py-3 rounded-full bg-[#3D4766] text-white text-sm font-semibold hover:bg-[#2f3855] transition-colors duration-200"
            >
              Register Now
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </article>

      </div>
    </div>
  </main>
</Layout>
