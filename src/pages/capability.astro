---
import Layout from "../layouts/Layout.astro";
import IntegratedTab from "../components/IntegratedTab.astro";
import ConsultationTab from "../components/ConsultationTab.astro";
import ResearchTab from "../components/ResearchTab.astro";
import UpskillingTab from "../components/UpskillingTab.astro";

const tabs = [
  {
    id: "integrated",
    target: "tab-content-integrated",
    label: "Integrated Capabilities",
    active: true,
  },
  {
    id: "consultation",
    target: "tab-content-consultation",
    label: "Consultation",
    active: false,
  },
  {
    id: "research",
    target: "tab-content-research",
    label: "Research",
    active: false,
  },
  {
    id: "upskilling",
    target: "tab-content-upskilling",
    label: "Upskilling",
    active: false,
  },
];

const capabilitySchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Clinical research consulting and upskilling",
  provider: {
    "@type": "Organization",
    name: "Siena Clinical",
    url: "https://www.sienaclinical.com/",
  },
  areaServed: "Indonesia",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Siena Clinical Capabilities",
    itemListElement: tabs.map((tab, index) => ({
      "@type": "OfferCatalog",
      position: index + 1,
      name: tab.label,
    })),
  },
};
---

<Layout
  title="Capabilities | Siena Clinical Clinical Research Services"
  description="Explore Siena Clinical capabilities in integrated healthcare solutions, clinical consultation, research support, and professional upskilling."
  structuredData={capabilitySchema}
>
  <main class="w-full min-h-screen pt-16 pb-24">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Tabs Layout -->
      <div class="border-b border-gray-200 relative">
        <nav
          class="-mb-px flex flex-nowrap overflow-x-auto gap-2 sm:gap-8 pb-1 scrollbar-none"
          role="tablist"
          aria-label="Capability tabs"
          id="capability-tabs"
        >
          {
            tabs.map((tab) => (
              <button
                type="button"
                role="tab"
                id={`tab-${tab.id}`}
                aria-controls={tab.target}
                aria-selected={tab.active ? "true" : "false"}
                data-target={tab.target}
                class:list={[
                  "tab-button whitespace-nowrap py-3 sm:py-4 px-2 border-b-2 text-sm font-medium tracking-wide transition-all duration-300 shrink-0",
                  tab.active
                    ? "border-siena-cyan text-siena-primary active-tab"
                    : "border-transparent text-gray-400 hover:text-gray-800 hover:border-gray-300",
                ]}
              >
                {tab.label}
              </button>
            ))
          }
        </nav>
      </div>

      <!-- Content Sections -->
      <div class="tab-contents">
        <!-- Integrated Capabilities Content -->
        <section
          id="tab-content-integrated"
          role="tabpanel"
          aria-labelledby="tab-integrated"
          class="tab-content block relative w-full max-w-5xl mx-auto py-10 opacity-100 transition-opacity duration-300 mt-20"
        >
          <IntegratedTab />
        </section>

        <!-- Consultation Content -->
        <section
          id="tab-content-consultation"
          role="tabpanel"
          aria-labelledby="tab-consultation"
          class="tab-content hidden relative w-full max-w-6xl mx-auto opacity-0 transition-opacity duration-300 mt-20"
        >
          <ConsultationTab />
        </section>

        <!-- Research Content -->
        <section
          id="tab-content-research"
          role="tabpanel"
          aria-labelledby="tab-research"
          class="tab-content hidden relative w-full max-w-7xl mx-auto py-10 opacity-0 transition-opacity duration-300 mt-10"
        >
          <ResearchTab />
        </section>

        <!-- Upskilling Content (Placeholder) -->
        <section
          id="tab-content-upskilling"
          role="tabpanel"
          aria-labelledby="tab-upskilling"
          class="tab-content hidden relative w-full max-w-5xl mx-auto pt-6 pb-10 opacity-0 transition-opacity duration-300"
        >
          <UpskillingTab />
        </section>
      </div>
    </div>
  </main>
</Layout>

<style>
  /* Hide horizontal scrollbar for tabs (keeps scroll behavior). */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const tabButtons = document.querySelectorAll(".tab-button");
    const tabContents = document.querySelectorAll(".tab-content");

    tabButtons.forEach((button) => {
      button.addEventListener("click", (e) => {
        e.preventDefault();
        const targetId = button.getAttribute("data-target");

        // Reset all buttons
        tabButtons.forEach((btn) => {
          btn.classList.remove(
            "border-siena-cyan",
            "text-siena-primary",
            "active-tab",
          );
          btn.classList.add(
            "border-transparent",
            "text-gray-400",
            "hover:text-gray-800",
            "hover:border-gray-300",
          );
          btn.removeAttribute("aria-current");
        });

        // Activate clicked button
        button.classList.add(
          "border-siena-cyan",
          "text-siena-primary",
          "active-tab",
        );
        button.classList.remove(
          "border-transparent",
          "text-gray-400",
          "hover:text-gray-800",
          "hover:border-gray-300",
        );
        button.setAttribute("aria-current", "page");

        // Switch contents
        tabContents.forEach((content) => {
          content.classList.remove("block");
          content.classList.add("hidden", "opacity-0");
        });

        if (!targetId) return;

        const targetContent = document.getElementById(targetId);
        if (targetContent) {
          targetContent.classList.remove("hidden");
          targetContent.classList.add("block");
          // Add small delay for opacity transition
          setTimeout(() => {
            targetContent.classList.remove("opacity-0");
            targetContent.classList.add("opacity-100");
          }, 10);
        }
      });
    });
  });
</script>
